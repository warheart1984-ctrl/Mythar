{
  "specification_type": "api_boundary_specification",
  "specification_timestamp": "2026-07-12T19:50:00Z",
  "specification_id": "ulx-aais-api-boundary-001",
  
  "boundary_overview": {
    "purpose": "Define HTTP/REST API boundary between ULX IDE (client) and AAIS (service) with constitutional governance",
    "architecture_pattern": "Service Orchestration with Constitutional API Gateway",
    "communication_protocol": "HTTP/1.1 or HTTP/2 with TLS",
    "data_format": "JSON with constitutional metadata headers"
  },
  
  "service_endpoints": {
    "base_url": "http://localhost:8000/api/v1",
    "authentication": "Constitutional Authority Tokens (CAT)",
    "endpoints": [
      {
        "path": "/governance/health",
        "method": "GET",
        "purpose": "Health check with constitutional status",
        "request": {},
        "response": {
          "status": "healthy|degraded|unhealthy",
          "constitutional_status": "compliant|violation|emergency",
          "timestamp": "ISO 8601"
        }
      },
      {
        "path": "/forge/evaluate",
        "method": "POST",
        "purpose": "Submit component for Forge evaluation (CUOS Law 1)",
        "request": {
          "component_type": "tool|workflow|module",
          "component_spec": "object",
          "ucdd_conformance_evidence": "object",
          "request_id": "UUID"
        },
        "response": {
          "evaluation_result": "pass|fail|conditional",
          "forge_normalization": "object",
          "constitutional_compliance": "object",
          "request_id": "UUID"
        }
      },
      {
        "path": "/jarvis/execute",
        "method": "POST",
        "purpose": "Execute governed operation through Jarvis",
        "request": {
          "operation": "string",
          "parameters": "object",
          "authority_delegation": "object",
          "ucdd_evidence": "object",
          "request_id": "UUID"
        },
        "response": {
          "execution_result": "object",
          "governance_status": "object",
          "constitutional_compliance": "object",
          "audit_trail_entry": "object",
          "request_id": "UUID"
        }
      },
      {
        "path": "/memory/query",
        "method": "POST",
        "purpose": "Query governed memory with constitutional constraints",
        "request": {
          "query": "string",
          "authority_scope": "object",
          "ucdd_traceability": "object",
          "request_id": "UUID"
        },
        "response": {
          "memory_results": "array",
          "governance_filter": "object",
          "constitutional_compliance": "object",
          "request_id": "UUID"
        }
      },
      {
        "path": "/governance/violation",
        "method": "POST",
        "purpose": "Report and handle constitutional violations",
        "request": {
          "violation_type": "string",
          "violation_details": "object",
          "constitutional_framework": "CUOS|UCDD",
          "severity": "low|medium|high|critical",
          "request_id": "UUID"
        },
        "response": {
          "violation_handled": "boolean",
          "escalation_level": "number",
          "remediation_actions": "array",
          "cross_system_impact": "object",
          "request_id": "UUID"
        }
      },
      {
        "path": "/audit/sync",
        "method": "POST",
        "purpose": "Synchronize audit trails between systems",
        "request": {
          "audit_entries": "array",
          "source_system": "ULX|AAIS",
          "sync_scope": "object",
          "request_id": "UUID"
        },
        "response": {
          "sync_status": "success|partial|failed",
          "correlated_entries": "array",
          "traceability_links": "array",
          "request_id": "UUID"
        }
      }
    ]
  },
  
  "constitutional_headers": {
    "required_headers": [
      {
        "header": "X-Constitutional-Authority",
        "description": "Authority delegation token from ULX IDE",
        "format": "Bearer <CAT-token>",
        "validation": "Token must be valid and within authority scope"
      },
      {
        "header": "X-UCDD-Conformance-Evidence",
        "description": "UCDD conformance evidence for request",
        "format": "JSON object reference",
        "validation": "Evidence must be valid and current"
      },
      {
        "header": "X-Request-ID",
        "description": "Unique request identifier for traceability",
        "format": "UUID v4",
        "validation": "Must be unique and traceable"
      },
      {
        "header": "X-Constitutional-Framework",
        "description": "Source constitutional framework",
        "format": "UCDD|CUOS|RECONCILIATION",
        "validation": "Must be valid framework identifier"
      },
      {
        "header": "X-Authority-Scope",
        "description": "Authority scope for this request",
        "format": "JSON object",
        "validation": "Scope must be within delegated authority"
      }
    ]
  },
  
  "constitutional_validation": {
    "request_validation": [
      "Validate Constitutional Authority Token",
